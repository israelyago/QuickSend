// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Send -> Package visual flow > shows file list table after selecting a file 1`] = `
<table
  class="min-w-full text-left text-sm"
>
  <thead>
    <tr
      class="border-b border-slate-200 dark:border-zinc-700 text-xs uppercase tracking-wide text-slate-500 dark:text-zinc-400"
    >
      <th
        class="px-3 py-2 font-medium"
      >
        Name
      </th>
      <th
        class="px-3 py-2 text-right font-medium"
      >
        File size
      </th>
      <th
        class="px-3 py-2 text-right font-medium"
      >
        Actions
      </th>
    </tr>
  </thead>
  <tbody
    class="divide-y divide-slate-200 dark:divide-zinc-700"
  >
    <tr
      class="bg-white dark:bg-zinc-900"
    >
      <td
        class="px-3 py-2"
      >
        <span
          class="block max-w-[420px] truncate text-slate-900 dark:text-zinc-100"
          title="demo.txt"
        >
          demo.txt
        </span>
      </td>
      <td
        class="px-3 py-2 text-right text-slate-600 dark:text-zinc-300"
      >
        1.0 KB
      </td>
      <td
        class="px-3 py-2 text-right"
      >
        <div
          class="relative inline-flex"
          data-file-actions="true"
        >
          <button
            aria-expanded="false"
            aria-haspopup="menu"
            aria-label="Open actions for demo.txt"
            class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-200 dark:border-zinc-700 text-slate-600 dark:text-zinc-300 transition hover:bg-slate-50 dark:hover:bg-zinc-800 hover:text-slate-900 dark:hover:text-zinc-100"
            type="button"
          >
            <svg
              aria-hidden="true"
              class="lucide lucide-ellipsis h-4 w-4"
              fill="none"
              height="24"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <circle
                cx="12"
                cy="12"
                r="1"
              />
              <circle
                cx="19"
                cy="12"
                r="1"
              />
              <circle
                cx="5"
                cy="12"
                r="1"
              />
            </svg>
          </button>
        </div>
      </td>
    </tr>
  </tbody>
</table>
`;
