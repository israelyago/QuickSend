{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quicksend",
  "version": "0.3.0",
  "identifier": "com.israelyagopereira.quicksend",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "quicksend",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1QzBBMjk5ODlFREQ3NUIKUldSYjErMkptYUxBRmV0ZTVERjc3NjdKL2lPdkFOZTFEekJVdGFsOTdrSitjRzBzL2xnb1hhT1EK",
      "endpoints": [
        "https://github.com/israelyago/QuickSend/releases/latest/download/latest.json"
      ]
    }
  }
}